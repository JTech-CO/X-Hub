{
  "manifest_version": 3,
  "name": "X Hub",
  "version": "3.1.0",
  "description": "All-in-one X toolkit: collect reposters, run raffles, check mutual follows, and filter tweets — no server required.",
  "icons": {
    "16": "icons/XH16.png",
    "48": "icons/XH48.png",
    "128": "icons/XH128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://api.x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fetch-interceptor.js"
      ],
      "matches": [
        "https://x.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "X Hub"
  }
}