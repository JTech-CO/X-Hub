{
  "manifest_version": 3,
  "name": "X Reposts Raffle",
  "version": "2.0.0",
  "description": "Collect retweeters, run raffles, and check mutual followers on X. No server required.",
  "icons": {
    "16": "icons/XRT16.png",
    "48": "icons/XRT48.png",
    "128": "icons/XRT128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*/status/*/retweets*",
        "https://twitter.com/*/status/*/retweets*",
        "https://x.com/*/followers",
        "https://x.com/*/followers/*",
        "https://x.com/*/following",
        "https://x.com/*/following/*",
        "https://twitter.com/*/followers",
        "https://twitter.com/*/followers/*",
        "https://twitter.com/*/following",
        "https://twitter.com/*/following/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "X Reposts Raffle"
  }
}
